<Project>
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <TargetPath>$(MSBuildThisFileDirectory)bin/aggregate-output-does-not-exist.dll</TargetPath>
    <VidraTsOutputDir>$(MSBuildThisFileDirectory)generated-missing</VidraTsOutputDir>
    <VidraCodeGenCommand>dotnet this-command-must-not-run</VidraCodeGenCommand>
  </PropertyGroup>

  <Import Project="../../../src/bridge/Vidra.Bridge/Vidra.CodeGen.targets" />
</Project>
